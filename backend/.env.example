# FlowMind Backend - Environment Variables
# Copy this file to .env and fill in your values

# ── SiliconFlow ──────────────────────────────
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# ── MySQL ──────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=flowmind123
MYSQL_DATABASE=flowmind

# ── JWT ────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-key

# ── SMTP 邮件发送 (忘记密码验证码) ──────────
# 支持任意 SMTP 服务：QQ邮箱、163、Gmail、Resend、Mailgun 等
# 不填则运行在 Demo 模式（验证码返回在 API 响应中）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password

# ── 虎皮椒支付 (Hupijiao) ─────────────────
# 申请地址: https://www.hupijiao.com
# 不填则运行在 Demo 模式（支付直接到账，不走真实支付）
HUPIJIAO_APP_ID=your_app_id
HUPIJIAO_APP_KEY=your_app_key

# 支付回调地址（必须是公网可访问的 URL，填 ngrok/内网穿透地址）
PAY_NOTIFY_URL=http://your-domain.com/api/pay/notify
PAY_RETURN_URL=http://your-domain.com/dashboard.html

# ── Server ─────────────────────────────────
PORT=3001
